# syntax=docker/dockerfile:1

# =============================================================================
# Stage 1: Desktop environment setup
# =============================================================================
FROM ubuntu:24.04 AS setup

ENV LANG='en_US.UTF-8'
ENV LANGUAGE='en_US.UTF-8'
ENV LC_ALL='en_US.UTF-8'

# Update and install core dependencies (desktop stack + development tools)
RUN apt-get update -y \
  && apt-get install -y --no-install-recommends \
  bash \
  build-essential \
  ca-certificates \
  curl \
  dbus-x11 \
  ffmpeg \
  git \
  imagemagick \
  libpq5 \
  locales \
  net-tools \
  novnc \
  openssl \
  pm-utils \
  psmisc \
  python-is-python3 \
  python3 \
  python3-dev \
  python3-pip \
  python3-tk \
  python3-venv \
  python3-wheel \
  scrot \
  software-properties-common \
  sqlite3 \
  sudo \
  unzip \
  vim \
  wget \
  x11vnc \
  xauth \
  xdotool \
  xfce4 \
  xfce4-terminal \
  xfonts-base \
  xvfb \
  && rm -rf /var/lib/apt/lists/*

RUN update-ca-certificates

# Install real Chromium from PPA (Ubuntu 24.04 only ships snap stubs that don't work in Docker)
RUN add-apt-repository ppa:xtradeb/apps -y \
  && apt-get update -y \
  && apt-get install -y chromium \
  && rm -rf /var/lib/apt/lists/*

# Remove snap stubs that don't work in Docker
RUN apt-get purge -y firefox chromium-browser 2>/dev/null; true

# Configure Chromium for Docker: disable sandbox, set policies
RUN echo "export CHROMIUM_FLAGS=--no-sandbox" >> /etc/chromium.d/default-flags
RUN mkdir -p /etc/chromium/policies/managed && \
    echo '{"DnsOverHttpsMode":"off","DefaultPopupsSetting":1,"SafeBrowsingProtectionLevel":1}' \
    > /etc/chromium/policies/managed/policy.json

# Set Chromium as default browser for XFCE and XDG
RUN mkdir -p /etc/xdg/xfce4 && \
    printf 'WebBrowser=chromium\n' > /etc/xdg/xfce4/helpers.rc && \
    mkdir -p /etc/xdg && \
    printf '[Default Applications]\ntext/html=chromium.desktop\nx-scheme-handler/http=chromium.desktop\nx-scheme-handler/https=chromium.desktop\n' \
    > /etc/xdg/mimeapps.list

ENV HOME=/home/ubuntu \
    DEBIAN_FRONTEND=noninteractive \
    DISPLAY=:1.0 \
    COMPUTER_WIDTH_PX=1280 \
    COMPUTER_HEIGHT_PX=800

EXPOSE 6080

# Suppress AT-SPI errors in Xfce
ENV NO_AT_BRIDGE=1

# Remove XFCE plugins that crash in Docker and cause popup dialogs
RUN apt-get purge -y xfce4-notifyd xfce4-statusnotifier-plugin 2>/dev/null; \
    rm -f /usr/lib/x86_64-linux-gnu/xfce4/panel/plugins/libsystray.so \
          /usr/lib/x86_64-linux-gnu/xfce4/panel/plugins/libstatusnotifier.so \
          /usr/lib/x86_64-linux-gnu/xfce4/panel/plugins/libnotification-plugin.so \
    2>/dev/null; true

# Create .cache and .config directories owned by ubuntu
RUN mkdir -p /home/ubuntu/.cache && chown -R ubuntu:ubuntu /home/ubuntu/.cache
RUN mkdir -p /home/ubuntu/.config && chown -R ubuntu:ubuntu /home/ubuntu/.config

WORKDIR /

# Setup dinit services
COPY dinit.d/ /etc/dinit.d/
RUN mkdir -p /var/log/dinit && chmod 755 /var/log/dinit

# MCP_TESTING_MODE controls tool registration:
#   "1" (default) = agent tools (computer, bash, editor)
#   "0"           = platform orchestration tools (setup_problem, grade_problem)
ARG MCP_TESTING_MODE="1"
ENV MCP_TESTING_MODE=${MCP_TESTING_MODE}

# =============================================================================
# Stage 2: HUD Environment Setup
# =============================================================================
FROM setup AS runtime

# Install uv for dependency management
RUN pip install uv --break-system-packages

# Copy the environment structure
COPY ./pyproject.toml /mcp_server/pyproject.toml
COPY ./uv.lock /mcp_server/uv.lock
WORKDIR /mcp_server

ENV RUST_LOG=warn
RUN uv venv && . .venv/bin/activate && uv sync --no-install-project --extra dev && uv pip install -e .
ENV PYTHONPATH=/mcp_server/.venv/lib/python3.12/site-packages:/mcp_server
ENV PATH=/mcp_server/.venv/bin:$PATH

# Copy application code
COPY ./env.py /mcp_server/env.py
COPY ./cli.py /mcp_server/cli.py
COPY ./dinit_setup.py /mcp_server/dinit_setup.py
COPY ./manual_dinit.py /mcp_server/manual_dinit.py
COPY ./grading /mcp_server/grading
COPY ./tasks /mcp_server/tasks

# Resolution environment variables — must be consistent across all settings
ENV COMPUTER_WIDTH_PX=1280
ENV COMPUTER_HEIGHT_PX=800
ENV DISPLAY_WIDTH=1280
ENV DISPLAY_HEIGHT=800
ENV DISPLAY_NUM=1

# Screenshot and downloads directories
RUN mkdir -p /home/ubuntu/screenshots && chmod 777 /home/ubuntu/screenshots
ENV SCREENSHOT_DIR=/home/ubuntu/screenshots
RUN mkdir -p /home/ubuntu/Downloads && chmod 777 /home/ubuntu/Downloads

# Security: agent cannot read grading logic or scenario internals
# The MCP server runs as root; agent tools demote to uid 1000 (ubuntu)
RUN chmod 700 /mcp_server/env.py /mcp_server/tasks /mcp_server/grading

# Required env vars — the platform injects these at runtime.
# These are declared in the scenario's required_env_vars, not in the Dockerfile.
# See: @env.scenario("cua-task", required_env_vars=["HUD_API_KEY", "ANTHROPIC_API_KEY"])

ENV _HUD_DEV_CHILD=1

# Entrypoint starts desktop services (dinit) before the main command
COPY --chmod=755 ./entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]

# Run the HUD MCP server
CMD ["hud", "dev", "env:env", "--stdio"]
